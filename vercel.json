{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "devCommand": "npx vite --host 127.0.0.1 --port $PORT",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/landing",
      "destination": "/landing.html"
    },
    {
      "source": "/",
      "destination": "/landing.html"
    }
  ]
}
